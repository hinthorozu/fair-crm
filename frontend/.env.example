VITE_API_BASE_URL=http://127.0.0.1:8001
# KYROX Core auth API. In Vite dev, defaults to http://127.0.0.1:5173/kyrox-core (proxied to Core :8000).
VITE_CORE_BASE_URL=
VITE_APP_ENV=development
# Dev bypass (single switch): true = skip login + use Bearer dev-bypass API headers;
# false = normal login/auth guard. Session JWT always takes priority over bypass when logged in.
# Production builds must keep this false (or unset).
VITE_DEV_BYPASS_ENABLED=true
VITE_DEV_BYPASS_TOKEN=dev-bypass
VITE_ORGANIZATION_ID=00000000-0000-4000-8000-000000000010
