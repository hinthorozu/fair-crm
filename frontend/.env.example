# Leave empty: API paths already start with /api/v1/... and use same-origin relative URLs.
# Local: Vite proxies /api -> http://127.0.0.1:8001
# Server: Nginx proxies /api/ -> http://127.0.0.1:8001
VITE_API_BASE_URL=
# Auth login/refresh/logout go through Fair CRM bridge: /api/v1/auth/* (HttpOnly refresh cookie).
# Optional direct Core base (legacy tools only). Empty → same-origin /kyrox-core.
VITE_CORE_BASE_URL=
VITE_APP_ENV=development
# Dev bypass (single switch): true = skip login + use Bearer dev-bypass API headers;
# false = normal login/auth guard. Session JWT always takes priority over bypass when logged in.
# Production builds must keep this false (or unset).
VITE_DEV_BYPASS_ENABLED=true
VITE_DEV_BYPASS_TOKEN=dev-bypass
VITE_ORGANIZATION_ID=00000000-0000-4000-8000-000000000010
