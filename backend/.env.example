# Fair CRM service
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fair_crm
# Must match KYROX Core JWT_SECRET_KEY for token validation after login.
JWT_SECRET_KEY=dev-insecure-change-me-use-env-in-production-32b
JWT_ALGORITHM=HS256
# Must match KYROX Core ACCESS_TOKEN_EXPIRE_MINUTES (short-lived access JWT).
ACCESS_TOKEN_EXPIRE_MINUTES=15
# HttpOnly refresh cookie Max-Age (minimum 15). Core REFRESH_TOKEN_EXPIRE_DAYS should be >= this.
REFRESH_TOKEN_EXPIRE_DAYS=15
# Local HTTP: false. Production HTTPS: true (also auto-forced when APP_ENV is not development/local/test).
FAIR_CRM_REFRESH_COOKIE_SECURE=false
FAIR_CRM_REFRESH_COOKIE_SAMESITE=lax
KYROX_CORE_BASE_URL=http://localhost:8000
APP_ENV=development
LOG_LEVEL=INFO

# Local dev without KYROX Core (development/local/test only)
FAIR_CRM_DEV_BYPASS_CORE=false
FAIR_CRM_DEV_BYPASS_TOKEN=dev-bypass
# FAIR_CRM_DEV_USER_ID=00000000-0000-4000-8000-000000000001
# FAIR_CRM_DEV_ORGANIZATION_ID=00000000-0000-4000-8000-000000000010
# Import upload safety limits (override in production as needed)
IMPORT_MAX_FILE_SIZE_MB=50
IMPORT_MAX_ROWS=50000
IMPORT_MAX_COLUMNS=100
IMPORT_MAX_SHEETS=20
IMPORT_MAPPING_SAMPLE_ROWS=10
IMPORT_GRID_PREVIEW_ROWS=50
IMPORT_ANALYZE_CHUNK_SIZE=500
